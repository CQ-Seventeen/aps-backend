<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.santoni.iot.aps.infrastructure.database.aps.ProduceOrderMapper">

    <resultMap id="result" type="com.santoni.iot.aps.infrastructure.po.ProduceOrderPO">
        <result column="id" jdbcType="BIGINT" property="id"/>
        <result column="outer_order_id" jdbcType="VARCHAR" property="outerId"/>
        <result column="org_id" jdbcType="VARCHAR" property="orgId"/>
        <result column="org_name" jdbcType="VARCHAR" property="orgName"/>
        <result column="code" jdbcType="VARCHAR" property="code"/>
        <result column="institute_id" jdbcType="BIGINT" property="instituteId"/>
        <result column="customer_code" jdbcType="VARCHAR" property="customerCode"/>
        <result column="customer_name" jdbcType="VARCHAR" property="customerName"/>
        <result column="delivery_time" jdbcType="TIMESTAMP" property="deliveryTime"/>
        <result column="manufacture_batch" jdbcType="VARCHAR" property="manufactureBatch"/>
        <result column="manufacture_date" jdbcType="TIMESTAMP" property="manufactureDate"/>
        <result column="status" jdbcType="TINYINT" property="status"/>
        <result column="create_time" jdbcType="TIMESTAMP" property="createTime"/>
        <result column="modified_time" jdbcType="TIMESTAMP" property="modifiedTime"/>
        <result column="creator_id" jdbcType="BIGINT" property="creatorId"/>
        <result column="operator_id" jdbcType="BIGINT" property="operatorId"/>
        <result column="deleted_at" jdbcType="BIGINT" property="deletedAt"/>
    </resultMap>

    <sql id="tableName">Produce_Order</sql>
    <sql id="insertColumns">
        outer_order_id,
        org_id,
        org_name,
        code,
        institute_id,
        customer_code,
        customer_name,
        delivery_time,
        manufacture_batch,
        manufacture_date,
        status,
        creator_id,
        operator_id
    </sql>

    <sql id="selectColumns">
        id,
        outer_order_id,
        org_id,
        org_name,
        code,
        institute_id,
        customer_code,
        customer_name,
        delivery_time,
        manufacture_batch,
        manufacture_date,
        status,
        create_time,
        modified_time,
        creator_id,
        operator_id,
        deleted_at
    </sql>

    <insert id="insert" parameterType="com.santoni.iot.aps.infrastructure.po.ProduceOrderPO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO
        <include refid="tableName"/>
        (
            <include refid="insertColumns"/>
        )
        VALUES
        (
            #{po.outerId},
            #{po.orgId},
            #{po.orgName},
            #{po.code},
            #{po.instituteId},
            #{po.customerCode},
            #{po.customerName},
            #{po.deliveryTime},
            #{po.manufactureBatch},
            #{po.manufactureDate},
            #{po.status},
            #{po.creatorId},
            #{po.operatorId}
        )
    </insert>

    <insert id="batchInsert" parameterType="com.santoni.iot.aps.infrastructure.po.ProduceOrderPO" >
        INSERT INTO
        <include refid="tableName"/>
        (
        <include refid="insertColumns"/>
        )
        VALUES
        <foreach collection="poList" item="po" separator=",">
            (
                #{po.outerId},
                #{po.orgId},
                #{po.orgName},
                #{po.code},
                #{po.instituteId},
                #{po.customerCode},
                #{po.customerName},
                #{po.deliveryTime},
                #{po.manufactureBatch},
                #{po.manufactureDate},
                #{po.status},
                #{po.creatorId},
                #{po.operatorId}
            )
        </foreach>

    </insert>

    <update id="update" parameterType="com.santoni.iot.aps.infrastructure.po.ProduceOrderPO">
        UPDATE
        <include refid="tableName"/>
        SET
            delivery_time = #{po.deliveryTime},
            status = #{po.status},
            operator_id = #{operatorId}
        WHERE
            id = #{po.id} and deleted_at = 0
    </update>

    <select id="getById" resultMap="result">
        SELECT
        <include refid="selectColumns"/>
        FROM
        <include refid="tableName"/>
        WHERE
            id = #{id} and deleted_at = 0
    </select>

    <select id="getByCode" resultMap="result">
        SELECT
        <include refid="selectColumns"/>
        FROM
        <include refid="tableName"/>
        WHERE
            institute_id = #{instituteId} and code = #{code} and deleted_at = 0
    </select>

    <select id="listByInstituteId" resultMap="result">
        SELECT
        <include refid="selectColumns"/>
        FROM
        <include refid="tableName"/>
        WHERE
            institute_id = #{instituteId} and deleted_at = 0
    </select>

    <select id="searchProduceOrder" resultMap="result">
        SELECT
        <include refid="selectColumns"/>
        FROM
        <include refid="tableName"/>
        WHERE institute_id = #{qo.instituteId} and deleted_at = 0
            <if test="qo.code != null and qo.code != ''">
                AND code like '%${qo.code}%'
            </if>
            <if test="qo.customerCode != null and qo.customerCode != ''">
                AND customer_code like '%${qo.customerCode}%'
            </if>
            <if test="qo.statusList != null and qo.statusList.size > 0">
                and status in
                <foreach collection="qo.statusList" item="status" open="(" separator="," close=")">
                    #{status}
                </foreach>
            </if>
            <if test="qo.deliveryTimeStart != null">
                and delivery_time &gt; #{qo.deliveryTimeStart}
            </if>
            <if test="qo.deliveryTimeEnd != null">
                and delivery_time &lt; #{qo.deliveryTimeEnd}
            </if>
    </select>

    <select id="listByStatus" resultMap="result">
        SELECT
            <include refid="selectColumns"/>
        FROM
            <include refid="tableName"/>
        WHERE institute_id = #{instituteId} and deleted_at = 0
            <if test="statusList != null and statusList.size > 0">
                and status in
                <foreach collection="statusList" item = "status" open="(" separator="," close=")">
                    #{status}
                </foreach>
            </if>
    </select>

    <select id="listByIdList" resultMap="result">
        SELECT
            <include refid="selectColumns"/>
        FROM
            <include refid="tableName"/>
        WHERE
            id in
            <foreach collection="idList" item="id" separator="," open="(" close=")">
                #{id}
            </foreach> and deleted_at = 0
    </select>

    <select id="listByCodeList" resultMap="result">
        SELECT
            <include refid="selectColumns"/>
        FROM
            <include refid="tableName"/>
        WHERE
            institute_id = #{instituteId} and
            code in
            <foreach collection="codeList" item="code" separator="," open="(" close=")">
                #{code}
            </foreach>
            and deleted_at = 0
    </select>

    <select id="searchProduceOrderByFactory" resultMap="result">
        SELECT
            <include refid="selectColumns"/>
        FROM
            (
            SELECT
                <include refid="selectColumns"/>
            FROM
                <include refid="tableName"/>
            WHERE institute_id = #{qo.instituteId} and deleted_at = 0

            <if test="qo.code != null and qo.code != ''">
                AND code like '%${qo.code}%'
            </if>
            <if test="qo.customerCode != null and qo.customerCode != ''">
                AND customer_code like '%${qo.customerCode}%'
            </if>
            <if test="qo.statusList != null and qo.statusList.size > 0">
                and status in
                <foreach collection="qo.statusList" item = "status" open="(" separator="," close=")">
                    #{status}
                </foreach>
            </if>
            <if test="qo.deliveryTimeStart != null">
                and delivery_time &gt; #{qo.deliveryTimeStart}
            </if>
            <if test="qo.deliveryTimeEnd != null">
                and delivery_time &lt; #{qo.deliveryTimeEnd}
            </if>
            )a
            INNER JOIN
            (
            SELECT produce_order_id
            FROM Factory_Planned_Task
            WHERE institute_id = #{qo.instituteId} and factory_id = #{factoryId} and deleted_at = 0
            )b on a.id = b.produce_order_id
    </select>
</mapper>