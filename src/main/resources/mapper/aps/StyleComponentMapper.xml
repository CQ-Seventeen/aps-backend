        WHERE
            institute_id = #{instituteId} and produce_order_code = #{orderCode} and sku_code = #{skuCode} and part = #{part} and deleted_at = 0
    </select>

    <select id="listBySkuAndPartPair" resultMap="result">
        SELECT
            <include refid="selectColumns"/>
        FROM
            <include refid="tableName"/>
        WHERE
            institute_id = #{instituteId}
            and (sku_code, part) in
            <foreach collection="pairList" item="pair" open="(" separator="," close=")">
