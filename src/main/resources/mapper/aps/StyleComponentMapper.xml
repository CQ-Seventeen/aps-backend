    <update id="update" parameterType="com.santoni.iot.aps.infrastructure.po.StyleComponentPO">
        UPDATE
        <include refid="tableName"/>
        SET
            program_file = #{po.programFile},
            type = #{po.type},
            number = #{po.number},
            ratio = #{po.ratio},
            cylinder_diameter = #{po.cylinderDiameter},
            needle_spacing = #{po.needleSpacing},
            description = #{po.description},
            expected_produce_time = #{po.expectedProduceTime},
            machine_requirement = #{po.machineRequirement},
            expected_weight = #{po.expectedWeight},
            standard_number = #{po.standardNumber},
            default_efficiency = #{po.defaultEfficiency},
            actual_efficiency = #{po.actualEfficiency},
            yarn_usage = #{po.yarnUsage},
            finish_width = #{po.finishWidth},
            finish_length = #{po.finishLength},
            waste_rate = #{po.wasteRate},
            dye = #{po.dye}
        WHERE
            institute_id = #{po.instituteId} and
            produce_order_code = #{po.produceOrderCode} and
            sku_code = #{po.skuCode} and
            part = #{po.part} and
            deleted_at = 0
    </update>

    <update id="delete" parameterType="com.santoni.iot.aps.infrastructure.po.StyleComponentPO">
        UPDATE
        <include refid="tableName"/>
        SET
            deleted_at = unix_timestamp(now())
        WHERE
            id = #{po.id} and deleted_at = 0
    </update>

    <update id="deleteBySkuCode">
        UPDATE
        <include refid="tableName"/>
        SET
            deleted_at = unix_timestamp(now())
        WHERE
            institute_id = #{instituteId} and sku_code = #{skuCode} and deleted_at = 0
    </update>

    <select id="findBySkuCode" resultMap="result">
        SELECT
            <include refid="selectColumns"/>
        FROM
            <include refid="tableName"/>
        WHERE
            institute_id = #{instituteId} and sku_code = #{skuCode} and deleted_at = 0
    </select>

    <select id="listBySkuCodeList" resultMap="result">
        SELECT
            <include refid="selectColumns"/>
        FROM
            <include refid="tableName"/>
        WHERE
            institute_id = #{instituteId} and
            sku_code in
            <foreach collection="codeList" item="code" open="(" separator="," close=")">
                #{code}
            </foreach> and deleted_at = 0
    </select>

    <select id="getBySkuCodeAndPart" resultMap="result">
        SELECT
            <include refid="selectColumns"/>
        FROM
            <include refid="tableName"/>
        WHERE
            institute_id = #{instituteId} and sku_code = #{skuCode} and part = #{part} and deleted_at = 0
