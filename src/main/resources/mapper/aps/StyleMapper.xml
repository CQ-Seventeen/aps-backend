<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.santoni.iot.aps.infrastructure.database.aps.StyleMapper">

    <resultMap id="result" type="com.santoni.iot.aps.infrastructure.po.StylePO">
        <result column="id" jdbcType="BIGINT" property="id"/>
        <result column="institute_id" jdbcType="BIGINT" property="instituteId"/>
        <result column="produce_order_id" jdbcType="VARCHAR" property="produceOrderId"/>
        <result column="produce_order_code" jdbcType="VARCHAR" property="produceOrderCode"/>
        <result column="style_id" jdbcType="VARCHAR" property="styleId"/>
        <result column="code" jdbcType="VARCHAR" property="code"/>
        <result column="symbol_id" jdbcType="VARCHAR" property="symbolId"/>
        <result column="symbol" jdbcType="VARCHAR" property="symbol"/>
        <result column="name" jdbcType="VARCHAR" property="name"/>
        <result column="description" jdbcType="VARCHAR" property="description"/>
        <result column="images" jdbcType="VARCHAR" property="images"/>
        <result column="create_time" jdbcType="TIMESTAMP" property="createTime"/>
        <result column="modified_time" jdbcType="TIMESTAMP" property="modifiedTime"/>
        <result column="deleted_at" jdbcType="BIGINT" property="deletedAt"/>
    </resultMap>

    <sql id="tableName">Style</sql>
    <sql id="insertColumns">
        institute_id,
        produce_order_id,
        produce_order_code,
        style_id,
        code,
        symbol_id,
        symbol,
        name,
        description,
        images
    </sql>

    <sql id="selectColumns">
        id,
        institute_id,
        produce_order_id,
        produce_order_code,
        style_id,
        code,
        symbol_id,
        symbol,
        name,
        description,
        images,
        create_time,
        modified_time,
        deleted_at
    </sql>

    <insert id="insert" parameterType="com.santoni.iot.aps.infrastructure.po.StylePO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO
        <include refid="tableName"/>
        (
            <include refid="insertColumns"/>
        )
        VALUES
        (
            #{po.instituteId},
            #{po.produceOrderId},
            #{po.produceOrderCode},
            #{po.styleId},
            #{po.code},
            #{po.symbolId},
            #{po.symbol},
            #{po.name},
            #{po.description},
            #{po.images}
        )
        ON DUPLICATE KEY UPDATE
            name = VALUES(name),
            description = VALUES(description)
    </insert>

    <insert id="batchInsert" parameterType="com.santoni.iot.aps.infrastructure.po.StylePO">
        INSERT INTO
        <include refid="tableName"/>
        (
            <include refid="insertColumns"/>
        )
        VALUES
            <foreach collection="poList" item="po" separator=",">
            (
                #{po.instituteId},
                #{po.produceOrderId},
                #{po.produceOrderCode},
                #{po.styleId},
                #{po.code},
                #{po.symbolId},
                #{po.symbol},
                #{po.name},
                #{po.description},
                #{po.images}
            )
            </foreach>
    </insert>

    <update id="update" parameterType="com.santoni.iot.aps.infrastructure.po.StylePO">
        UPDATE
        <include refid="tableName"/>
        SET
            produce_order_id = #{po.produceOrderId},
            produce_order_code = #{po.produceOrderCode},
            symbol_id = #{po.symbolId},
            symbol = #{po.symbol},
            name = #{po.name},
            description = #{po.description},
            images = #{po.images}
        WHERE
            id = #{po.id} and deleted_at = 0
    </update>

    <update id="batchUpdate" parameterType="com.santoni.iot.aps.infrastructure.po.StylePO">
        <foreach collection="poList" item="po" separator=";">
            UPDATE
            <include refid="tableName"/>
            SET
                name = #{po.name},
                description = #{po.description},
                images = #{po.images}
            WHERE
                id = #{po.id} and deleted_at = 0
        </foreach>
    </update>

    <select id="getByCode" resultMap="result">
        SELECT
        <include refid="selectColumns"/>
        FROM
        <include refid="tableName"/>
        WHERE
            institute_id = #{instituteId} and produce_order_code is null and code = #{code} and deleted_at = 0
    </select>

    <select id="getByOrderAndCode" resultMap="result">
        SELECT
        <include refid="selectColumns"/>
        FROM
        <include refid="tableName"/>
        WHERE
        institute_id = #{instituteId} and produce_order_code = #{orderCode} and code = #{code} and deleted_at = 0
    </select>

    <select id="getById" resultMap="result">
        SELECT
        <include refid="selectColumns"/>
        FROM
        <include refid="tableName"/>
        WHERE
            id = #{id} and deleted_at = 0
    </select>

    <select id="listByCodeList" resultMap="result">
        SELECT
        <include refid="selectColumns"/>
        FROM
        <include refid="tableName"/>
        WHERE
            institute_id = #{instituteId} and
            code in
            <foreach collection="codeList" item="code" open="(" separator="," close=")">
                #{code}
            </foreach>
            and deleted_at = 0
    </select>

    <select id="searchStyle" resultMap="result">
        SELECT
            <include refid="selectColumns"/>
        FROM
            <include refid="tableName"/>
        WHERE institute_id = #{instituteId} and deleted_at = 0
            <if test="qo.code != null and qo.code != ''">
                AND code like '%${qo.code}%'
            </if>
    </select>

    <select id="lockByOrderAndCode" resultMap="result">
        SELECT
            <include refid="selectColumns"/>
        FROM
            <include refid="tableName"/>
        WHERE institute_id = #{instituteId} and produce_order_code = #{orderCode} and code = #{code} and deleted_at = 0
        FOR UPDATE
    </select>
</mapper>