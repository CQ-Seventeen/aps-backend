    <select id="getAllMachineType" resultType="java.lang.String">
        SELECT distinct machine_type
        FROM
            <include refid="tableName"/>
        WHERE
            institute_id = #{instituteId} and deleted_at = 0
    </select>

    <select id="getAllBareSpandexType" resultType="java.lang.String">
        SELECT distinct bare_spandex_type
        FROM
            <include refid="tableName"/>
        WHERE
            institute_id = #{instituteId} and deleted_at = 0
    </select>

    <select id="getAllSize" resultMap="machineSize">
        SELECT distinct
            cylinder_diameter,
            needle_spacing,
            needle_number
        FROM
            <include refid="tableName"/>
        WHERE
            institute_id = #{instituteId} and deleted_at = 0
    </select>

    <select id="listByInstituteId" resultMap="result">
        SELECT
            <include refid="selectColumns"/>
